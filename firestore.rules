rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'petedianotech@gmail.com' ||
        request.auth.token.email == 'mscepreparation@gmail.com'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Collections ---

    // Users
    match /users/{userId} {
      function isValidUser(data) {
        return data.get('name', '') is string && 
               data.get('email', '') is string;
      }

      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(request.resource.data);
                      
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Materials
    match /materials/{materialId} {
      function isValidMaterial(data) {
        return data.title is string && data.title.size() <= 200 &&
               data.content is string && data.content.size() <= 1000000 &&
               data.type in ['pdf', 'video', 'text']; // Removed authorId check since admin can create it
      }

      allow read: if true;
      allow write: if isAdmin() && isValidId(materialId);
    }

    // Videos section
    match /videos/{videoId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(videoId);
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(notificationId);
    }
  }
}
